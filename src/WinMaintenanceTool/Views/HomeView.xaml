<UserControl x:Class="WinMaintenanceTool.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Subtitle}" Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.85" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <ui:Card Margin="0,0,0,10" Padding="18">
                <StackPanel>
                    <TextBlock Text="SFC" FontWeight="SemiBold" FontSize="20" />
                    <TextBlock Text="{Binding SfcDescription}" TextWrapping="Wrap" Margin="0,8,0,10" />
                    <Button Content="{Binding OpenSfcLabel}" Height="40" FontSize="14"
                            Command="{Binding DataContext.NavigateSfcCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="18">
                <StackPanel>
                    <TextBlock Text="DISM" FontWeight="SemiBold" FontSize="20" />
                    <TextBlock Text="{Binding DismDescription}" TextWrapping="Wrap" Margin="0,8,0,10" />
                    <Button Content="{Binding OpenDismLabel}" Height="40" FontSize="14"
                            Command="{Binding DataContext.NavigateDismCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </Grid>
</UserControl>
