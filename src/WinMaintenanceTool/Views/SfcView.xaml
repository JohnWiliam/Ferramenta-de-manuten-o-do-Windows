<UserControl x:Class="WinMaintenanceTool.Views.SfcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1" Text="{Binding Description}" Margin="0,8,0,14" TextWrapping="Wrap" />

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Actions}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:Card Margin="0,0,0,8" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,0" Opacity="0.9" />
                            </StackPanel>

                            <Button Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0"
                                    Content="{Binding DataContext.RunButtonLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Command="{Binding DataContext.RunCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ui:Card Grid.Row="3" Margin="0,10,0,0" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding ExecutionLogTitle}" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Grid.Row="1" Margin="0,6,0,10" Text="{Binding SelectedActionTitle}" Opacity="0.85" />
                <ProgressBar Grid.Row="2" Height="8" Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}" />
                <ScrollViewer Grid.Row="3" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="{Binding Output}" FontFamily="Consolas" TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
