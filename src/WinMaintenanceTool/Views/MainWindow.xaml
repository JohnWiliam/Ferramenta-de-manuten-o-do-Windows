<ui:FluentWindow x:Class="WinMaintenanceTool.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:WinMaintenanceTool.ViewModels"
                 xmlns:views="clr-namespace:WinMaintenanceTool.Views"
                 mc:Ignorable="d"
                 Title="{Binding AppTitle}"
                 Width="920"
                 Height="680"
                 MinWidth="860"
                 MinHeight="620"
                 ResizeMode="CanResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SfcViewModel}">
            <views:SfcView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DismViewModel}">
            <views:DismView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding AppTitle}" />

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:Card Grid.Row="0" Padding="10" Margin="0,0,0,12">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Command="{Binding NavigateHomeCommand}" ToolTip="{Binding NavHomeLabel}" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home24" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding NavHomeLabel}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button DockPanel.Dock="Right" Command="{Binding NavigateSettingsCommand}" ToolTip="{Binding NavSettingsLabel}" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding NavSettingsLabel}" />
                        </StackPanel>
                    </Button>
                </DockPanel>
            </ui:Card>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
